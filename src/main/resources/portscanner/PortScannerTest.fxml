<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="util.portScanner.controller.PortScannerController">
   <children>
      <VBox prefHeight="0.0" prefWidth="290.0" spacing="10.0">
         <children>
            <HBox prefHeight="0.0" prefWidth="285.0" spacing="10.0">
               <children>
                  <Label text="IP Address :" />
                  <TextField fx:id="scannerIP" prefWidth="200.0" />
               </children>
            </HBox>
            <HBox prefHeight="0.0" prefWidth="285.0" spacing="10.0">
               <children>
                  <Label text="Start Port :" />
                  <TextField fx:id="scannerStartPort" prefWidth="200.0" />
               </children>
            </HBox>
            <HBox prefHeight="0.0" prefWidth="285.0" spacing="10.0">
               <children>
                  <Label text="End Port :" />
                  <TextField fx:id="scannerEndPort" prefWidth="200.0" />
               </children>
            </HBox>
            <HBox alignment="BOTTOM_RIGHT" prefHeight="55.0" prefWidth="285.0" spacing="10.0">
               <children>
                  <VBox alignment="BOTTOM_RIGHT">
                     <children>
                     <Button onAction="#handleReset" mnemonicParsing="false" text="Clear" />
                     </children>
                     <padding>
                        <Insets bottom="10.0" left="0.0" right="0.0" top="10.0" />
                     </padding>
                  </VBox>
                  <VBox alignment="BOTTOM_RIGHT" >
                     <children>
                        <Label fx:id="statusLabel" text="" />
                        <Button onAction="#handleScan" mnemonicParsing="false" text="Start Scan" />
                     </children>
                     <padding>
                        <Insets bottom="10.0" left="0.0" right="10.0" top="10.0" />
                     </padding>
                  </VBox>
               </children>
            </HBox>
            <HBox alignment="CENTER_RIGHT" prefHeight="100.0" prefWidth="285.0" style="-fx-padding: 0 10 0 0;">
               <children>
                  <VBox alignment="TOP_LEFT" >
                     <children>
                        <Label fx:id="allLabel" text="" onMouseClicked="#showAll"/>
                        <Label fx:id="openLabel" text="" onMouseClicked="#showOpen"/>
                        <Label fx:id="closeLabel" text="" onMouseClicked="#showClose"/>
                        <Label fx:id="filteredLabel" text="" onMouseClicked="#showFilter"/>
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
      </VBox>
      <VBox prefHeight="200.0" prefWidth="300.0">
         <children>
            <TableView fx:id="resultTable" prefHeight="427.0" prefWidth="295.0">
              <columns>
                <TableColumn fx:id="portColumn" prefWidth="75.0" text="Port" />
                <TableColumn fx:id="statusColumn" prefWidth="220.0" text="Status" />
              </columns>
            </TableView>
         </children>
      </VBox>
   </children>
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>
</HBox>
