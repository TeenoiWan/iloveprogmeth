<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.control.RadioButton?>

<HBox alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="util.hashGenerator.controller.HashGeneratorController">
   <children>
      <VBox prefWidth="400.0" spacing="10.0">
         <children>
            <VBox spacing="5.0">
               <children>
                  <Label text="Enter text to be hashed" wrapText="true" />
                  <HBox prefHeight="0.0" prefWidth="280.0" spacing="10.0">
                     <children>
                        <fx:define><ToggleGroup fx:id="hashModeGroup"/></fx:define>
                        <RadioButton fx:id="hashTextModeBtn" mnemonicParsing="false" toggleGroup="$hashModeGroup" text="text" selected="true"/>
                        <RadioButton fx:id="hashFileModeBtn" mnemonicParsing="false" toggleGroup="$hashModeGroup" text="file" />
                     </children>
                  </HBox>
                  <StackPane prefHeight="100.0" prefWidth="400.0" fx:id="hashInputStack">
                     <children>
                        <VBox prefHeight="75.0" prefWidth="200.0" fx:id="hashFilePane" visible="false" managed="false" >
                           <Label text="File Input"/>
                        <HBox spacing="10.0">
                           <children>
                              <TextField fx:id="hashFilePath"/>
                              <Button onAction="#handleHashFileSelect" text="Browse" />
                           </children>
                        </HBox>
                        </VBox>
                        <VBox fx:id="hashTextPane">
                           <Label text="Text Input"/>
                        <TextArea prefHeight="68.0" prefWidth="400.0" fx:id="hashInput" />
                        </VBox>
                     </children>
                  </StackPane>
               </children>
            </VBox>
            <HBox prefHeight="23.0" prefWidth="400.0" spacing="10.0">
               <children>
                  <CheckBox mnemonicParsing="false" text="MD5" fx:id="md5Check" selected="true"/>
                  <CheckBox mnemonicParsing="false" text="SHA-1" fx:id="sha1Check" selected="false"/>
                  <CheckBox mnemonicParsing="false" text="SHA-256" fx:id="sha256Check" selected="false"/>
                  <CheckBox mnemonicParsing="false" text="SHA-512" fx:id="sha512Check" selected="false"/>
               </children>
            </HBox>
            <Button mnemonicParsing="false" text="Generate" onAction="#handleHash"/>
            <Button text="clear" onAction="#handleReset"/>
            <VBox prefHeight="200.0" prefWidth="100.0" fx:id="hashOutputArea">
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
            </VBox>
         </children>
      </VBox>
   </children>
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>
</HBox>
